{
  "name": "cross-wms",
  "version": "1.0.0",
  "buildCommand": "npm run edgeone:build",
  "outputDirectory": "dist",
  "functionsDirectory": "edge-functions",
  "routes": [
    {
      "src": "/_next/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/api/(.*)",
      "function": "api/index"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
